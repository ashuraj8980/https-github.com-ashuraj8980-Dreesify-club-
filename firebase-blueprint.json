{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An item available for sale in the e-commerce store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "salePrice": { "type": "number" },
        "discountPercentage": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "number" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "isTrending": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "salePrice", "images", "category", "sizes", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer's purchase record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "shipping": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "packed", "shipped", "delivered", "cancelled"] },
        "paymentMethod": { "type": "string", "enum": ["cod", "online"] },
        "paymentId": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "paymentMethod", "shippingAddress"]
    },
    "Customer": {
      "title": "Customer",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "addresses": { "type": "array" },
        "wishlist": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discounts that can be applied to orders.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["percentage", "fixed"] },
        "value": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "usageLimit": { "type": "number" },
        "usedCount": { "type": "number" }
      },
      "required": ["code", "type", "value"]
    },
    "Review": {
      "title": "Review",
      "description": "Product ratings and comments from customers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating"]
    }
  },
  "firestore": {
    "/products": { "schema": "Product", "description": "Collection of available products." },
    "/orders": { "schema": "Order", "description": "Collection of customer orders." },
    "/customers": { "schema": "Customer", "description": "User profiles and data." },
    "/coupons": { "schema": "Coupon", "description": "Available discount coupons." },
    "/reviews": { "schema": "Review", "description": "Product reviews." },
    "/settings": { "schema": "object", "description": "Site-wide configuration." }
  }
}
